import java.util.Scanner;

public class Main {
  public static void main(String[] args) {
    Scanner scanner = new Scanner(System.in);

    if (scanner.hasNext()) {
      String s = scanner.next();
      String target = "hello";
      int targetIndex = 0;

      // Iterate through Vasya's typed word
      for (int i = 0; i < s.length(); i++) {
        // If current character matches the character we need next
        if (s.charAt(i) == target.charAt(targetIndex)) {
          targetIndex++;
        }

        // If we found all characters of "hello" in order, we can stop early
        if (targetIndex == target.length()) {
          break;
        }
      }

      // If targetIndex reached 5, it means "hello" was fully found
      if (targetIndex == target.length()) {
        System.out.println("YES");
      } else {
        System.out.println("NO");
      }
    }

    scanner.close();
  }
}
